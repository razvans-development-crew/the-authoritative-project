datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  recursive_type_depth = 5
}

// privilege levels:
// 0 = no privileges, no whitelist
// 1 = no privileges, whitelist
// 2 = remote admin usage, whitelist
// 3 = remote admin usage + user bans, whitelist
// 4 = remote admin usage + user bans + group bans, whitelist
// 5 = all permissions from below + admin, whitelist
// 6 = owner
model TAPWhitelist {
  id                     String @id @map("_id") @default(uuid())
  whitelisted_at         DateTime @default(now())
  discord_user_id        String @unique
  rx_user_name           String
  rx_user_id             BigInt 
  rank                   String @default("user")
  privilege_level        Int @default(1)
}

model TAPGlobalUserBan {
  id                     String @id @map("_id") @default(uuid())
  banned_at              DateTime @default(now())
  moderator_dc_id        String
  rx_user_name           String @unique
  rx_user_id             BigInt @unique
  reason                 String
  duration               Int @default(-1) // -1 = permanent
}

model TAPGlobalGroupBan {
  id                     String @id @map("_id") @default(uuid())
  banned_at              DateTime @default(now())
  moderator_dc_id        String
  rx_group_name          String
  rx_group_id            BigInt @unique
  reason                 String
  duration               Int @default(-1) // -1 = permanent
}

// legacy entries
model whitelist {
  id                     String @id @map("_id") @default(uuid())
  whitelisted_at         DateTime @default(now())
  dc_user_id             String @unique
  rx_user_name           String
  rx_user_id             BigInt
  rank                   String @default("User")
  privilege_level        Int @default(1)
}

model global_user_ban {
  id                     String @id @map("_id") @default(uuid())
  banned_at              DateTime @default(now())
  moderator              String
  rx_user_name           String
  rx_user_id             BigInt @unique
  reason                 String @default("No reason provided")
}

model global_group_ban {
  id                     String @id @map("_id") @default(uuid())
  banned_at              DateTime @default(now())
  moderator              String
  group_id               BigInt @unique
  group_name             String
  reason                 String @default("No reason provided")
}